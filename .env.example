# Database
# Required in production. PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gbmedix?schema=public"

# Authentication
# Required in production. Use a long random secret, at least 32 bytes.
AUTH_SECRET="change-me-to-a-long-random-secret"
# Public app origin used by checkout redirects and absolute URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional comma-separated admin emails for admin-only APIs.
ADMIN_EMAILS=""

# AI Provider
# Required for real AI report generation.
# Do not switch production to AI_PROVIDER=deepseek until cross-border/third-party
# AI processing consent has been reviewed and released.
AI_PROVIDER="openai"
AI_MODEL=""
OPENAI_MODEL=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL=""
# Reserved for future providers. Do not enable until implemented and reviewed.
QWEN_API_KEY=""
QWEN_BASE_URL=""
KIMI_API_KEY=""
KIMI_BASE_URL="https://api.moonshot.ai/v1"
GLM_API_KEY=""
DOUBAO_API_KEY=""

# Stripe
# Required for Stripe Checkout and webhook verification in production.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Optional Payment Provider
# Optional. Only set if Alipay redirect checkout is enabled.
ALIPAY_CHECKOUT_URL=""

# Email
# Required in production because email verification gates AI assessment access.
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM="GB Medix AI <verify@your-domain.example>"
AWS_SES_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
SENDGRID_API_KEY=""

# Proxy
# Keep false unless a trusted edge proxy overwrites the configured IP header.
TRUST_PROXY_HEADERS="false"
TRUST_PROXY_IP_HEADER=""
