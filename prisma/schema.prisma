generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String          @id @default(cuid())
  email     String          @unique
  createdAt DateTime        @default(now())
  payments  PaymentRecord[]
}

model TCMRecord {
  id        String   @id @default(cuid())
  input     String
  result    String
  createdAt DateTime @default(now())
}

model PaymentRecord {
  id        String   @id @default(cuid())
  userId    String?
  status    String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
