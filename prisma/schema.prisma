generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                      @id @default(cuid())
  email                  String                      @unique
  status                 String                      @default("pending")
  sessionVersion         Int                         @default(1)
  emailVerifiedAt        DateTime?
  createdAt              DateTime                    @default(now())
  payments               PaymentRecord[]
  tcmRecords             TCMRecord[]
  rfqRecords             RFQRecord[]
  assistantSessions      AssistantSession[]
  consultationOrders     ConsultationOrder[]
  entitlements           Entitlement[]
  aiUsages               AIUsage[]
  conversations          Conversation[]
  aiReports              AIReport[]
  productRecommendations ProductRecommendation[]
  patientConsents        PatientConsent[]
  emailVerifications     EmailVerification[]
  aiProcessingConsents   AIProcessingConsent[]
  deviceSessions         DeviceSession[]
  mobileAuthRateLimits   MobileAuthRateLimitBucket[]

  @@index([status])
  @@index([createdAt])
}

// Batch 2.2B — Mobile device sessions (persistent, transactional refresh rotation).
// Timestamps are stored as DateTime; the store maps them to/from epoch SECONDS and
// re-validates every loaded row (a `number`/`DateTime` is NOT trusted at runtime).
// DB CHECK constraints enforce the same invariants as the pure-function foundation.
model DeviceSession {
  id                    String                 @id @default(cuid())
  userId                String
  tokenFamilyId         String                 @unique
  status                String                 @default("active")
  rotationCounter       Int                    @default(0)
  refreshTokenHash      String                 @unique
  createdAt             DateTime
  lastUsedAt            DateTime
  idleExpiresAt         DateTime
  absoluteExpiresAt     DateTime
  revokedAt             DateTime?
  revokeReason          String?
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumedRefreshTokens ConsumedRefreshToken[]

  @@unique([id, tokenFamilyId])
  @@index([userId])
  @@index([status])
  @@index([idleExpiresAt])
  @@index([absoluteExpiresAt])
  @@index([userId, status])
}

// Previously-rotated (consumed) refresh token hashes, retained for replay
// detection until at least the owning session's absolute expiry. ONLY the hash is
// stored — never a token, email, phone, header, cookie, pepper, or health data.
model ConsumedRefreshToken {
  id               String        @id @default(cuid())
  deviceSessionId  String
  tokenFamilyId    String
  refreshTokenHash String        @unique
  consumedAt       DateTime
  expiresAt        DateTime
  deviceSession    DeviceSession @relation(fields: [deviceSessionId, tokenFamilyId], references: [id, tokenFamilyId], onDelete: Cascade)

  @@index([deviceSessionId])
  @@index([tokenFamilyId])
  @@index([expiresAt])
}

// Batch 2.2D - Mobile auth API security controls. These tables persist only
// de-identified digests and enum state for request hardening; they never store
// raw tokens, Authorization headers, Idempotency-Key values, request JSON, email,
// phone, patient, health, payment, provider, cookie, pepper, or signing keys.
model MobileAuthRateLimitBucket {
  id            String   @id @default(cuid())
  endpoint      String
  subjectDigest String
  bucketKey     String   @unique
  windowStart   DateTime
  windowSeconds Int
  count         Int      @default(0)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([endpoint, subjectDigest])
  @@index([expiresAt])
  @@index([userId])
}

model MobileAuthIdempotencyRecord {
  id               String    @id @default(cuid())
  endpoint         String
  keyDigest        String    @unique
  actorDigest      String
  credentialDigest String
  requestDigest    String
  status           String
  createdAt        DateTime  @default(now())
  expiresAt        DateTime
  completedAt      DateTime?

  @@index([endpoint])
  @@index([actorDigest])
  @@index([credentialDigest])
  @@index([expiresAt])
  @@index([status])
}

model MobileAuthAuditLog {
  id              String   @id @default(cuid())
  event           String
  reason          String?
  outcome         String
  occurredAt      DateTime
  userId          String?
  deviceSessionId String?
  tokenFamilyId   String?
  createdAt       DateTime @default(now())

  @@index([event])
  @@index([outcome])
  @@index([occurredAt])
  @@index([userId])
  @@index([deviceSessionId])
  @@index([tokenFamilyId])
}

model Merchant {
  id          String    @id @default(cuid())
  email       String    @unique
  storeName   String
  contactName String
  country     String
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Product {
  id              String                  @id @default(cuid())
  merchantId      String
  name            String
  category        String
  price           String
  stock           String
  imageUrl        String
  description     String
  status          String                  @default("active")
  createdAt       DateTime                @default(now())
  merchant        Merchant                @relation(fields: [merchantId], references: [id])
  recommendations ProductRecommendation[]

  @@index([merchantId])
  @@index([status])
  @@index([category])
}

model TCMRecord {
  id        String     @id @default(cuid())
  userId    String?
  kind      String     @default("tcm_analysis")
  input     String
  result    String
  createdAt DateTime   @default(now())
  user      User?      @relation(fields: [userId], references: [id])
  reports   AIReport[]

  @@index([userId])
  @@index([createdAt])
}

model PaymentRecord {
  id              String        @id @default(cuid())
  userId          String?
  provider        String        @default("stripe")
  product         String        @default("body_reset_plan")
  sessionId       String?       @unique
  paymentIntentId String?
  resourceType    String?
  resourceId      String?
  status          String
  amountCents     Int           @default(999)
  currency        String        @default("usd")
  createdAt       DateTime      @default(now())
  user            User?         @relation(fields: [userId], references: [id])
  entitlements    Entitlement[]

  @@index([userId])
  @@index([product])
  @@index([paymentIntentId])
  @@index([resourceType, resourceId])
  @@index([status])
  @@index([createdAt])
}

model RFQRecord {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  company         String
  email           String
  country         String
  productInterest String
  quantity        Int
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([country])
  @@index([createdAt])
}

model AssistantSession {
  id        String   @id @default(cuid())
  userId    String?
  lang      String
  mode      String
  input     String
  result    String
  hasImage  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([mode])
  @@index([createdAt])
}

model Doctor {
  id              String              @id @default(cuid())
  email           String              @unique
  name            String
  specialty       String
  status          String              @default("beta")
  createdAt       DateTime            @default(now())
  orders          ConsultationOrder[]
  verification    DoctorVerification?
  patientConsents PatientConsent[]
}

model ConsultationOrder {
  id        String   @id @default(cuid())
  userId    String
  doctorId  String?
  question  String
  summary   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([userId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
}

model Entitlement {
  id           String        @id @default(cuid())
  userId       String
  productId    String
  paymentId    String
  resourceType String?
  resourceId   String?
  status       String        @default("active")
  expiresAt    DateTime?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id])
  payment      PaymentRecord @relation(fields: [paymentId], references: [id])

  @@unique([paymentId, productId])
  @@index([userId])
  @@index([productId])
  @@index([resourceType, resourceId])
  @@index([status])
  @@index([expiresAt])
}

model AIUsage {
  id        String   @id @default(cuid())
  userId    String
  ip        String   @default("unknown")
  provider  String   @default("openai")
  model     String
  tokens    Int
  cost      Float
  endpoint  String   @default("unknown")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([ip])
  @@index([provider])
  @@index([model])
  @@index([provider, model])
  @@index([endpoint])
  @@index([createdAt])
}

model AIProcessingConsent {
  id             String    @id @default(cuid())
  userId         String
  provider       String
  consentVersion String
  acceptedAt     DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider])
  @@index([consentVersion])
  @@index([revokedAt])
  @@index([userId, provider, consentVersion, revokedAt])
}

model DoctorVerification {
  id            String   @id @default(cuid())
  doctorId      String   @unique
  licenseNumber String
  country       String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  doctor        Doctor   @relation(fields: [doctorId], references: [id])

  @@index([status])
  @@index([country])
}

model PatientConsent {
  id        String   @id @default(cuid())
  userId    String
  doctorId  String?
  status    String   @default("granted")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([userId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  type      String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokens         Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

model AIReport {
  id                     String                  @id @default(cuid())
  userId                 String
  assessmentId           String?
  type                   String                  @default("health_assessment")
  status                 String                  @default("completed")
  score                  Int
  summary                String
  analysis               Json                    @db.JsonB
  recommendations        Json                    @db.JsonB
  lifestylePlan          Json                    @db.JsonB
  productSuggestions     Json                    @db.JsonB
  followUpPlan           Json                    @db.JsonB
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  user                   User                    @relation(fields: [userId], references: [id])
  assessment             TCMRecord?              @relation(fields: [assessmentId], references: [id])
  productRecommendations ProductRecommendation[]

  @@unique([userId, assessmentId, type])
  @@index([userId])
  @@index([assessmentId])
  @@index([type])
  @@index([status])
  @@index([score])
  @@index([createdAt])
}

model ProductRecommendation {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  productId String?
  category  String
  title     String
  reason    String
  score     Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  report    AIReport @relation(fields: [reportId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([reportId])
  @@index([productId])
  @@index([category])
  @@index([score])
  @@index([createdAt])
}

model EmailVerification {
  id         String    @id @default(cuid())
  userId     String
  email      String
  token      String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@index([verifiedAt])
}
