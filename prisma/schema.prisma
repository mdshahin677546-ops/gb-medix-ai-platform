generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  createdAt         DateTime           @default(now())
  payments          PaymentRecord[]
  tcmRecords        TCMRecord[]
  rfqRecords        RFQRecord[]
  assistantSessions AssistantSession[]
  consultationOrders ConsultationOrder[]
  entitlements      Entitlement[]
  aiUsages          AIUsage[]
  conversations     Conversation[]
  aiReports         AIReport[]
  patientConsents   PatientConsent[]
}

model Merchant {
  id          String    @id @default(cuid())
  email       String    @unique
  storeName   String
  contactName String
  country     String
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Product {
  id          String   @id @default(cuid())
  merchantId  String
  name        String
  category    String
  price       String
  stock       String
  imageUrl    String
  description String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  merchant    Merchant @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
  @@index([status])
  @@index([category])
}

model TCMRecord {
  id        String   @id @default(cuid())
  userId    String?
  kind      String   @default("tcm_analysis")
  input     String
  result    String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  reports   AIReport[]

  @@index([userId])
  @@index([createdAt])
}

model PaymentRecord {
  id          String   @id @default(cuid())
  userId      String?
  provider    String   @default("stripe")
  product     String   @default("body_reset_plan")
  sessionId   String?  @unique
  status      String
  amountCents Int      @default(999)
  currency    String   @default("usd")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
  entitlements Entitlement[]

  @@index([userId])
  @@index([product])
  @@index([status])
  @@index([createdAt])
}

model RFQRecord {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  company         String
  email           String
  country         String
  productInterest String
  quantity        Int
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([country])
  @@index([createdAt])
}

model AssistantSession {
  id        String   @id @default(cuid())
  userId    String?
  lang      String
  mode      String
  input     String
  result    String
  hasImage  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([mode])
  @@index([createdAt])
}

model Doctor {
  id        String              @id @default(cuid())
  email     String              @unique
  name      String
  specialty String
  status    String              @default("beta")
  createdAt DateTime            @default(now())
  orders    ConsultationOrder[]
  verification DoctorVerification?
  patientConsents PatientConsent[]
}

model ConsultationOrder {
  id        String   @id @default(cuid())
  userId    String
  doctorId  String?
  question  String
  summary   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([userId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
}

model Entitlement {
  id        String    @id @default(cuid())
  userId    String
  productId String
  paymentId String
  status    String    @default("active")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  payment   PaymentRecord @relation(fields: [paymentId], references: [id])

  @@unique([paymentId, productId])
  @@index([userId])
  @@index([productId])
  @@index([status])
  @@index([expiresAt])
}

model AIUsage {
  id        String   @id @default(cuid())
  userId    String
  ip        String   @default("unknown")
  model     String
  tokens    Int
  cost      Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([ip])
  @@index([model])
  @@index([createdAt])
}

model DoctorVerification {
  id            String   @id @default(cuid())
  doctorId      String   @unique
  licenseNumber String
  country       String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  doctor        Doctor   @relation(fields: [doctorId], references: [id])

  @@index([status])
  @@index([country])
}

model PatientConsent {
  id        String   @id @default(cuid())
  userId    String
  doctorId  String?
  status    String   @default("granted")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  doctor    Doctor?  @relation(fields: [doctorId], references: [id])

  @@index([userId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  type      String
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  tokens         Int          @default(0)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

model AIReport {
  id              String    @id @default(cuid())
  userId          String
  assessmentId    String?
  content         String
  score           Int
  recommendations String
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id])
  assessment      TCMRecord? @relation(fields: [assessmentId], references: [id])

  @@index([userId])
  @@index([assessmentId])
  @@index([score])
  @@index([createdAt])
}
